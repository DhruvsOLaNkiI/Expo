# Google Gemini API Key for AI Chatbox
# Get your FREE API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_api_key_here

# Optional: model id for REST generateContent (default: gemini-3.1-flash-lite-preview)
# VITE_GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional: lock Ask AI to one deck — facts only (overrides CMS Scene → AI deck context). Use \n for newlines in a single line.
# VITE_AI_DECK_CONTEXT=Project: Vertex Elite. Location: ...\nConfigurations: 4–6 BHK.\nStarting from: ...

# Optional: max output tokens per reply (128–8192). Raise if answers cut off mid-sentence.
# VITE_GEMINI_MAX_OUTPUT_TOKENS=2048

# Example: VITE_GEMINI_API_KEY=AIzaSyD...
